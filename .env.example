# API base URL for the frontend to reach the backend.
# In development: set to http://localhost:4000 (the Express API server port).
# In production: leave empty or unset so the frontend uses relative URLs
#   and the Express server serves both the API and the built frontend on the same port.
VITE_API_BASE_URL=http://localhost:4000
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_key
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id
